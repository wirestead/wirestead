@PACKAGE_INIT@

include(CMakeFindDependencyMacro)
find_dependency(
  wirestead CONFIG REQUIRED HINTS "${CMAKE_CURRENT_LIST_DIR}/../wirestead"
)

if(TARGET wirestead::wirestead_shared AND NOT TARGET unilink::unilink_shared)
  add_library(unilink::unilink_shared INTERFACE IMPORTED)
  target_link_libraries(
    unilink::unilink_shared INTERFACE wirestead::wirestead_shared
  )
endif()

if(TARGET wirestead::wirestead_static AND NOT TARGET unilink::unilink_static)
  add_library(unilink::unilink_static INTERFACE IMPORTED)
  target_link_libraries(
    unilink::unilink_static INTERFACE wirestead::wirestead_static
  )
endif()

if(NOT TARGET unilink::unilink)
  add_library(unilink::unilink INTERFACE IMPORTED)
  target_link_libraries(unilink::unilink INTERFACE wirestead::wirestead)
endif()

check_required_components(unilink)
