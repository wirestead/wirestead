prefix=${pcfiledir}/@WIRESTEAD_PKGCONFIG_PREFIX_FROM_PCFILEDIR@
exec_prefix=${prefix}
libdir=${pcfiledir}/..
includedir=${prefix}/@WIRESTEAD_PKGCONFIG_INCLUDEDIR_FROM_PREFIX@

Name: wirestead
Description: A cross-platform asynchronous C++ communication library providing a unified API for Serial, TCP, UDP, and UDS transports
URL: https://github.com/wirestead/wirestead
Version: @PROJECT_VERSION@
Requires: @PKGCONFIG_REQUIRES@
Requires.private: @PKGCONFIG_REQUIRES_PRIVATE@
Libs: -L${libdir} -lwirestead
Libs.private: @PKGCONFIG_LIBS_PRIVATE@
Cflags: -I${includedir} @PKGCONFIG_CFLAGS@
